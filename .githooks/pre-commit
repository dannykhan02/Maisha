#!/bin/bash
# =========================================================
# .githooks/pre-commit
# Secrets-scanning git hook — blocks commits containing
# hardcoded API keys before they reach the repo.
#
# Scans staged file contents for:
#   - GCP keys (AIza...)
#   - Anthropic keys (sk-ant-...)
#   - Twilio SIDs (AC.../SK...)
#
# Blocks commit with clear message if match found.
# Bypass with: git commit --no-verify
# =========================================================

set -e

# Color codes for output
RED='\033[0;31m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Patterns to scan for
GCP_PATTERN='AIza[0-9A-Za-z\-_]{35}'
ANTHROPIC_PATTERN='sk-ant-[a-zA-Z0-9_-]{20,}'
TWILIO_SID_PATTERN='(AC[a-zA-Z0-9]{32}|SK[a-zA-Z0-9]{32})'

# Get all staged files and their contents
STAGED_FILES=$(git diff --cached --name-only)

if [ -z "$STAGED_FILES" ]; then
  exit 0
fi

FOUND_SECRETS=0

# Check each staged file for secret patterns
while IFS= read -r file; do
  # Skip deleted files
  if ! git cat-file -e ":0:$file" 2>/dev/null; then
    continue
  fi

  # Get staged content
  STAGED_CONTENT=$(git show ":0:$file" 2>/dev/null || true)

  # Check for GCP keys
  if echo "$STAGED_CONTENT" | grep -qE "$GCP_PATTERN"; then
    echo -e "${RED}✗ BLOCKED: GCP API key detected in $file${NC}"
    FOUND_SECRETS=1
  fi

  # Check for Anthropic keys
  if echo "$STAGED_CONTENT" | grep -qE "$ANTHROPIC_PATTERN"; then
    echo -e "${RED}✗ BLOCKED: Anthropic API key detected in $file${NC}"
    FOUND_SECRETS=1
  fi

  # Check for Twilio SIDs
  if echo "$STAGED_CONTENT" | grep -qE "$TWILIO_SID_PATTERN"; then
    echo -e "${RED}✗ BLOCKED: Twilio SID detected in $file${NC}"
    FOUND_SECRETS=1
  fi
done <<< "$STAGED_FILES"

if [ $FOUND_SECRETS -eq 1 ]; then
  echo ""
  echo -e "${YELLOW}Commit blocked: hardcoded secrets detected.${NC}"
  echo -e "${YELLOW}If this is a false positive, bypass with: git commit --no-verify${NC}"
  exit 1
fi

exit 0
